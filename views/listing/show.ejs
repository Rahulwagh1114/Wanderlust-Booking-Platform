<% layout("/layouts/boilerplate") %>
<body>
   
    <div class="row mt-3">
      <div class="col-8 offset-3">
         <h3>Listing Deatils:</h3>
      </div>
       <div class="card show-card col-6 offset-3">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing-image">
        <div class="card-body">
          <p class="card-text"><b><%= listing.title %></b><br>
            <%= listing.description %><br>
             &#8377;<%= listing.price.toLocaleString("en-IN") %><br>
             <%= listing.location %><br>
             <%= listing.country %>

          </p>
        </div>
       

       <div class="btns">
       <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-2 offst-2" style="background-color:#fe424d;">Edit </a>

    <form method="Post" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-dark offset-4">Delete </button>
    </form>
      </div>
    </div>
    </div>
</body>
