<% layout("/layouts/boilerplate") %>
<body>
   
    <div class="row mt-3">
      <div class="col-8 offset-3">
         <h3><%= listing.title %></h3>
      </div>
       <div class="card show-card col-6 offset-3 listing-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing-image">
        <div class="card-body">
          <p class="card-text">
            <%= listing.description %><br>
             &#8377;<%= listing.price.toLocaleString("en-IN") %><br>
             <%= listing.location %><br>
             <%= listing.country %>

          </p>
        </div>
       

       <div class="btns">
       <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-2 offst-2" style="background-color:#fe424d;">Edit </a>

    <form method="Post" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-dark offset-4">Delete </button>
    </form>
      </div>
    </div>
        <hr>
        <div class="col-8 offset-3 mb-3">
        <h4>Leave Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
          <div class="mb-3 mt-3 ">
            <label for="rating" class="form-label" >Rating</label>
            <input type="range" min="1" max="5" id="rating" class="form-range" name="review[rating]">
          </div>
          <div class="mb-3 mt-3">
            <label for="comment" class="form-label">Comment</label>
            <textarea name="review[comment]" id="comment" cols="30" row="5" class="form-control" required></textarea>
            <div class="invalid-feedback">Please add some comment</div>
          </div>
          <button class="btn btn-outline-dark">Submit</button>
        </form>
        <hr>
        <p><b>All reviews</b></p>
      
          <div class="row">
       <% for(let review  of listing.reviews){%> 
           <div class="card col-5 mb-3 ms-3 ">
            <div class="card-body"></div>
            <h5 class="card-title">Jane Doe</h5>
            <p class="card-text"><%= review.comment %></p>
            <p class="card-text"><%= review.rating %> stars</p>
            <form class="mb-3" method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
              <button class="btn btm-sm btn-dark">Delete</button>
            </form>
           </div>
        <% } %>
        </div>

        </div>
    </div>
</body>
